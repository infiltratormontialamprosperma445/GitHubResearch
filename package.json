{
  "name": "githubresearch",
  "version": "1.0.1",
  "description": "Local-first desktop GitHub research intelligence workspace. Track and classify trending repositories across AI, developer tools, and open-source ecosystems.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "prepare:icons": "powershell -ExecutionPolicy Bypass -File scripts/create-windows-icon.ps1",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "tsc -b && npm run build:main && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run build && electron .",
    "pack:win": "npm run prepare:icons && npm run build && electron-builder --win --dir",
    "dist:win": "npm run prepare:icons && npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:zip": "npm run build && electron-builder --mac zip --x64 --arm64",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run dist:win && npm run dist:mac:zip",
    "dist": "npm run dist:win",
    "test": "vitest run"
  },
  "keywords": [
    "github",
    "trending",
    "electron",
    "intelligence",
    "ai",
    "telegram",
    "twitter",
    "desktop-app",
    "sqlite",
    "react",
    "typescript",
    "developer-tools",
    "cross-platform"
  ],
  "author": "zrz2004",
  "license": "MIT",
  "type": "module",
  "build": {
    "appId": "com.githubresearch.app",
    "productName": "GitHubResearch",
    "executableName": "GitHubResearch",
    "copyright": "Copyright © 2025 zrz2004",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "artifactName": "GitHubResearch-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/*.map",
      "!**/node_modules/sql.js/**",
      "!**/node_modules/.cache/**",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**",
      "!**/node_modules/**/__tests__/**",
      "!**/node_modules/**/docs/**",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/*.ts",
      "!**/scripts/**",
      "!**/docs/**",
      "!**/.github/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GitHubResearch",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "GitHubResearch-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "synopsis": "GitHub Intelligence Workspace",
      "description": "Local-first research workspace for tracking, searching, and classifying trending GitHub repositories."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zrz2004",
        "repo": "GitHubResearch",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
